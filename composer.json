{
    "name": "ihumbak/woo-invoices",
    "description": "WooCommerce plugin for generating invoices, receipts and corrections",
    "type": "wordpress-plugin",
    "version": "0.4.0",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "iHumbak"
        }
    ],
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": "^8.0",
        "dompdf/dompdf": "^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "mockery/mockery": "^1.5",
        "squizlabs/php_codesniffer": "^3.7",
        "wp-coding-standards/wpcs": "^3.0",
        "phpstan/phpstan": "^1.10",
        "szepeviktor/phpstan-wordpress": "^1.3"
    },
    "autoload": {
        "psr-4": {
            "IHumbak\\Invoices\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "IHumbak\\Invoices\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "phpcs": "phpcs",
        "phpcbf": "phpcbf",
        "phpstan": "phpstan analyse --memory-limit=1G",
        "check": [
            "@phpcs",
            "@phpstan",
            "@test"
        ]
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        },
        "sort-packages": true,
        "platform": {
            "php": "8.0.0"
        }
    }
}
